#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.debug.xcconfig"
#include "Generated.xcconfig"

// === Rust Static Lib Linker Config ===
// The goal: Force iOS linker to include ALL symbols from our Rust static library

// 1. Disable all stripping
DEPLOYMENT_POSTPROCESSING = NO
STRIP_INSTALLED_PRODUCT = NO
DEAD_CODE_STRIPPING = NO
COPY_PHASE_STRIP = NO

// 2. Select the Rust static library by SDK
RUST_STATIC_LIB_PATH[sdk=iphoneos*] = $(PROJECT_DIR)/libs/iphoneos/libnovella_native.a
RUST_STATIC_LIB_PATH[sdk=iphonesimulator*] = $(PROJECT_DIR)/libs/iphonesimulator/libnovella_native.a

// 3. Linker flags
OTHER_LDFLAGS = $(inherited) -force_load "$(RUST_STATIC_LIB_PATH)" -ObjC -lc++
